# Copy this file to .streamlit/secrets.toml and fill in real values.
# secrets.toml is where actual secrets belong — never commit that file
# to git. On Streamlit Community Cloud, paste the same key/value pairs
# into your app's Settings → Secrets panel instead of using a file at all.

# Required to let people create new accounts via the "Create account" tab.
# Anyone who has this string can sign up. Change it any time to stop
# letting new people join with the old one.
SIGNUP_KEY = "put-your-own-invite-phrase-here"

# Optional: pre-provision durable accounts that survive container restarts
# (self-signup accounts are stored in a local file, which Streamlit
# Community Cloud can wipe on redeploy/sleep — see backend/auth.py).
[USERS]
# someuser = "somepassword"
